// MoniKid — Firestore Security Rules
// Schema source of truth: docs/firebase_document_design.md
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() { return request.auth != null; }

    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    function requesterDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function requesterExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function targetUserDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isParent() {
      return requesterExists() && requesterDoc().role == 'parent';
    }

    function isFamilyMember(familyId) {
      return requesterExists() && requesterDoc().family_id == familyId;
    }

    function isFamilyParent(familyId) {
      return isParent() && requesterDoc().family_id == familyId;
    }

    function hasNoFamily() {
      return requesterExists()
        && (!requesterDoc().keys().hasAny(['family_id'])
            || requesterDoc().family_id == null);
    }

    // family_id equality check already implies non-null on requester side.
    function isParentViewingChild(uid) {
      return isParent()
        && requesterDoc().family_id == targetUserDoc(uid).family_id
        && targetUserDoc(uid).role == 'child';
    }

    // ─── User ─────────────────────────────────────────────────────────────────

    function isValidUserCreate(uid) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'user_id', 'email', 'display_name', 'avatar_url', 'role',
          'monthly_limit', 'family_id', 'custom_categories',
          'created_at', 'updated_at'
        ])
        && data.keys().hasAll(['user_id', 'email', 'role', 'created_at'])
        && data.user_id == uid
        && data.email is string
     
      
        && (data.role == 'parent' || data.role == 'child')
        && data.created_at is timestamp && data.updated_at is timestamp
      
  
        && (data.get('monthly_limit', null) == null
            || (data.monthly_limit is int && data.monthly_limit >= 0))
        && data.get('family_id', null) == null;
    }

    function isValidUserProfileUpdate(uid) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let data = request.resource.data;
      return isSelf(uid)
        && diff.hasOnly(['display_name', 'avatar_url', 'monthly_limit', 'updated_at'])
        && data.updated_at is timestamp
        && (!diff.hasAny(['display_name'])
            || (data.display_name is string
                && data.display_name.size() > 0 && data.display_name.size() <= 80))
        && (!diff.hasAny(['avatar_url'])
            || data.avatar_url == null
            || (data.avatar_url is string && data.avatar_url.size() <= 2048))
        && (!diff.hasAny(['monthly_limit'])
            || data.monthly_limit == null
            || (data.monthly_limit is int && data.monthly_limit >= 0));
    }

    // custom_categories subcollection doc — fields: category_id, label, icon, type, created_at.
    function isValidCustomCategoryDoc(categoryId) {
      let data = request.resource.data;
      return data.keys().hasOnly(['category_id', 'label', 'icon', 'type', 'created_at'])
        && data.keys().hasAll(['category_id', 'label', 'icon', 'type', 'created_at'])
        && data.category_id == categoryId
        && data.label is string && data.label.size() > 0 && data.label.size() <= 40
        && data.icon is string && data.icon.size() > 0 && data.icon.size() <= 16
        && (data.type == 'expense' || data.type == 'income')
        && data.created_at is timestamp;
    }

    function isValidFamilyJoin(uid) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isSelf(uid)
        && hasNoFamily()
        && diff.hasOnly(['family_id', 'updated_at'])
        && request.resource.data.family_id is string
        && request.resource.data.family_id.size() > 0
        && request.resource.data.updated_at is timestamp;
    }

    // Clears family_id — covers self-leave and parent removing a child.
    function isValidFamilyClearMembership(uid) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return diff.hasOnly(['family_id', 'updated_at'])
        && request.resource.data.get('family_id', null) == null
        && request.resource.data.updated_at is timestamp
        && (isSelf(uid) || isParentViewingChild(uid));
    }

    function isValidParentSetChildLimit(childUid) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isParentViewingChild(childUid)
        && diff.hasOnly(['monthly_limit', 'updated_at'])
        && request.resource.data.updated_at is timestamp
        && (request.resource.data.monthly_limit == null
            || (request.resource.data.monthly_limit is int
                && request.resource.data.monthly_limit >= 0));
    }

    // ─── Transaction ──────────────────────────────────────────────────────────

    function isValidEvidenceImage(data) {
      let img = data.get('evidence_image', null);
      return img == null
        || (img is map
            && img.keys().hasOnly(['image_url', 'image_name', 'image_type', 'uploaded_at'])
            // image_url null = local mode; non-null = cloudinary public ID or URL (validated in app).
            && (img.get('image_url', null) == null
                || (img.image_url is string
                    && img.image_url.size() > 0 && img.image_url.size() <= 2048))
            && (img.get('image_name', null) == null
                || (img.image_name is string && img.image_name.size() <= 160))
            && (img.get('image_type', null) == null
                || img.image_type == 'image/jpeg' || img.image_type == 'image/png')
            && (img.get('uploaded_at', null) == null || img.uploaded_at is timestamp));
    }

    function isValidTransactionCreate(uid) {
      let data = request.resource.data;
      return isSelf(uid)
        && data.keys().hasOnly([
            'transaction_id', 'type', 'amount', 'category_id',
            'note', 'receipt_name', 'transaction_date',
            'created_at', 'updated_at', 'evidence_image'
          ])
        && data.keys().hasAll([
            'transaction_id', 'type', 'amount', 'category_id',
            'transaction_date', 'created_at', 'updated_at'
          ])
        && data.transaction_id is string && data.transaction_id.size() > 0
        && (data.type == 'expense' || data.type == 'income')
        && data.amount is int && data.amount > 0
        && data.category_id is string && data.category_id.size() > 0
        && (data.get('note', null) == null
            || (data.note is string && data.note.size() <= 300))
        && (data.get('receipt_name', null) == null
            || (data.receipt_name is string && data.receipt_name.size() <= 120))
        && data.transaction_date is timestamp
        && data.created_at is timestamp && data.updated_at is timestamp
        && isValidEvidenceImage(data);
    }

    // diff.hasOnly guarantees transaction_id and created_at are unchanged — no need to re-check.
    function isValidTransactionUpdate(uid) {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isSelf(uid)
        && diff.hasOnly([
            'type', 'amount', 'category_id', 'note',
            'receipt_name', 'transaction_date', 'updated_at', 'evidence_image'
          ])
        && (data.type == 'expense' || data.type == 'income')
        && data.amount is int && data.amount > 0
        && data.category_id is string && data.category_id.size() > 0
        && (data.get('note', null) == null
            || (data.note is string && data.note.size() <= 300))
        && (data.get('receipt_name', null) == null
            || (data.receipt_name is string && data.receipt_name.size() <= 120))
        && data.transaction_date is timestamp && data.updated_at is timestamp
        && isValidEvidenceImage(data);
    }

    // ─── Monthly summary ──────────────────────────────────────────────────────

    function isValidMonthlySummaryWrite(uid, monthKey) {
      let data = request.resource.data;
      return monthKey.matches('^[0-9]{4}-[0-9]{2}$')
        && data.keys().hasOnly(['month_key', 'user_id', 'total_expense', 'total_income', 'updated_at'])
        && data.keys().hasAll(['month_key', 'user_id', 'total_expense', 'total_income', 'updated_at'])
        && data.month_key == monthKey
        && data.user_id == uid
        && data.total_expense is int && data.total_income is int
        && data.updated_at is timestamp;
    }

    // ─── FAQ item ─────────────────────────────────────────────────────────────

    function isValidFaqItemCreate(faqId) {
      let data = request.resource.data;
      return data.keys().hasOnly(['faq_id', 'question', 'answer', 'created_at'])
        && data.keys().hasAll(['faq_id', 'question', 'answer', 'created_at'])
        && data.faq_id == faqId
        && data.question is string && data.question.size() > 0
        && data.answer is string && data.answer.size() > 0
        && data.created_at is timestamp;
    }

    // diff.hasOnly guarantees faq_id and created_at are unchanged — no need to re-check.
    function isValidFaqItemUpdate() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let data = request.resource.data;
      return diff.hasOnly(['question', 'answer'])
        && data.question is string && data.question.size() > 0
        && data.answer is string && data.answer.size() > 0;
    }

    // ─── Family ───────────────────────────────────────────────────────────────

    // members may include creator as initial owner (optional). Absent or [] also valid.
    function isValidFamilyCreate(familyId) {
      let data = request.resource.data;
      let members = data.get('members', []);
      return isParent()
        && hasNoFamily()
        && data.keys().hasOnly(['family_id', 'invite_code', 'created_at', 'updated_at', 'members'])
        && data.keys().hasAll(['family_id', 'created_at', 'updated_at'])
        && data.family_id == familyId
        && data.created_at is timestamp && data.updated_at is timestamp
        && (data.get('invite_code', null) == null
            || (data.invite_code is string && data.invite_code.matches('^[A-Z0-9]{6}$')))
        && (members == []
            || (members.size() == 1
                && members[0].user_id == request.auth.uid
                && members[0].role == 'owner'
                && isValidMemberEntry(members[0])));
    }

    // diff.hasOnly guarantees family_id and created_at are unchanged — no need to re-check.
    function isValidFamilyInviteCodeUpdate(familyId) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let data = request.resource.data;
      return isFamilyParent(familyId)
        && diff.hasOnly(['invite_code', 'updated_at'])
        && data.updated_at is timestamp
        && (data.invite_code == null
            || (data.invite_code is string && data.invite_code.matches('^[A-Z0-9]{6}$')));
    }

    function isValidMemberEntry(entry) {
      return entry is map
        && entry.keys().hasOnly(['user_id', 'role', 'user_role', 'display_name', 'avatar_url'])
        && entry.keys().hasAll(['user_id', 'role', 'user_role', 'display_name'])
        && entry.user_id is string && entry.user_id.size() > 0
        && (entry.role == 'owner' || entry.role == 'member')
        && (entry.user_role == 'parent' || entry.user_role == 'child')
        && entry.display_name is string
        && entry.display_name.size() > 0 && entry.display_name.size() <= 80
        && (entry.get('avatar_url', null) == null
            || (entry.avatar_url is string && entry.avatar_url.size() <= 2048));
    }

    // Grows by exactly 1. New entry appended last, must be requester. Existing entries frozen.
    function isValidMemberJoin(familyId) {
      let newMembers = request.resource.data.get('members', []);
      let oldMembers = resource.data.get('members', []);
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let newEntry = newMembers[newMembers.size() - 1];
      return hasNoFamily()
        && diff.hasOnly(['members', 'updated_at'])
        && request.resource.data.updated_at is timestamp
        && newMembers is list
        && newMembers.size() == oldMembers.size() + 1
        && newMembers.size() <= 5
        && newEntry.user_id == request.auth.uid
        && newEntry.role == 'member'
        && isValidMemberEntry(newEntry)
        && (oldMembers.size() < 1 || newMembers[0] == oldMembers[0])
        && (oldMembers.size() < 2 || newMembers[1] == oldMembers[1])
        && (oldMembers.size() < 3 || newMembers[2] == oldMembers[2])
        && (oldMembers.size() < 4 || newMembers[3] == oldMembers[3]);
    }

    // Shrinks by exactly 1. Any family member may remove (parent or self — enforced by app).
    function isValidMemberRemove(familyId) {
      let newMembers = request.resource.data.get('members', []);
      let oldMembers = resource.data.get('members', []);
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isFamilyMember(familyId)
        && diff.hasOnly(['members', 'updated_at'])
        && request.resource.data.updated_at is timestamp
        && newMembers is list
        && newMembers.size() == oldMembers.size() - 1;
    }

    // Same size — a member syncs their display_name / avatar_url after profile update.
    function isValidMembersSync(familyId) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isFamilyMember(familyId)
        && diff.hasOnly(['members', 'updated_at'])
        && request.resource.data.updated_at is timestamp
        && request.resource.data.get('members', []).size()
            == resource.data.get('members', []).size();
    }

    // ─── Invite code ──────────────────────────────────────────────────────────

    function isValidInviteCodeCreate(code) {
      let data = request.resource.data;
      return isParent()
        && requesterDoc().family_id != null
        && data.keys().hasOnly(['code', 'family_id', 'expired_at'])
        && data.keys().hasAll(['code', 'family_id', 'expired_at'])
        && data.code == code
        && data.code.matches('^[A-Z0-9]{6}$')
        && data.family_id == requesterDoc().family_id
        && data.expired_at is timestamp;
    }

    // ─── Match blocks ─────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSelf(uid) || isParentViewingChild(uid);
      allow create: if isSelf(uid) && isValidUserCreate(uid);
      allow update: if isValidUserProfileUpdate(uid)
        || isValidFamilyJoin(uid)
        || isValidFamilyClearMembership(uid)
        || isValidParentSetChildLimit(uid);
      allow delete: if false;

      match /custom_categories/{categoryId} {
        allow read: if isSelf(uid) || isParentViewingChild(uid);
        allow create: if isSelf(uid) && isValidCustomCategoryDoc(categoryId);
        allow update: if false;          // add-only, no edit
        allow delete: if isSelf(uid);    // owner-only delete
      }

      match /transactions/{transactionId} {
        allow read: if isSelf(uid) || isParentViewingChild(uid);
        allow create: if isValidTransactionCreate(uid);
        allow update: if isValidTransactionUpdate(uid);
        allow delete: if false;
      }

      match /monthly_summaries/{monthKey} {
        allow read: if isSelf(uid) || isParentViewingChild(uid);
        allow create: if isSelf(uid) && isValidMonthlySummaryWrite(uid, monthKey);
        allow update: if isSelf(uid) && isValidMonthlySummaryWrite(uid, monthKey);
        allow delete: if false;
      }

      match /faq_items/{faqId} {
        allow read: if isSelf(uid);
        allow create: if isSelf(uid) && isValidFaqItemCreate(faqId);
        allow update: if isSelf(uid) && isValidFaqItemUpdate();
        allow delete: if false;
      }
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId) || hasNoFamily();
      allow create: if isValidFamilyCreate(familyId);
      allow update: if isValidFamilyInviteCodeUpdate(familyId)
        || isValidMemberJoin(familyId)
        || isValidMemberRemove(familyId)
        || isValidMembersSync(familyId);
      allow delete: if false;
    }

    match /invite_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isValidInviteCodeCreate(code);
      allow delete: if isFamilyParent(
          get(/databases/$(database)/documents/invite_codes/$(code)).data.family_id
        );
      allow update: if false;
    }
    match /faqs/{language}/items/{faqId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
