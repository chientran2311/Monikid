rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function requesterExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function targetUserExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function requesterDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function targetUserDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validRole(role) {
      return role == 'parent' || role == 'child';
    }

    function validMemberStatus(status) {
      return status == 'active' || status == 'inactive';
    }

    function validTransactionType(type) {
      return type == 'expense' || type == 'income';
    }

    function validTransactionSource(source) {
      return source == 'manual' || source == 'ocr';
    }

    function isParent() {
      return requesterExists()
        && requesterDoc().data.role == 'parent'
        && requesterDoc().data.member_status == 'active';
    }

    function isFamilyMember(familyId) {
      return requesterExists()
        && requesterDoc().data.family_id == familyId
        && requesterDoc().data.member_status == 'active';
    }

    function isSameFamilyWithUser(uid) {
      return requesterExists()
        && targetUserExists(uid)
        && requesterDoc().data.family_id != null
        && requesterDoc().data.family_id == targetUserDoc(uid).data.family_id;
    }

    function isParentViewingChild(uid) {
      return isParent()
        && isSameFamilyWithUser(uid)
        && targetUserDoc(uid).data.role == 'child';
    }

    function isValidPreferences(preferences) {
      return preferences.keys().hasOnly(['currency', 'language'])
        && (!preferences.keys().hasAny(['currency']) || preferences.currency == 'VND')
        && (!preferences.keys().hasAny(['language']) || preferences.language is string);
    }

    function isValidSpendingAlert(alert) {
      return alert.keys().hasOnly(['enabled', 'daily_limit_minor', 'monthly_limit_minor'])
        && (!alert.keys().hasAny(['enabled']) || alert.enabled is bool)
        && (!alert.keys().hasAny(['daily_limit_minor']) || (alert.daily_limit_minor is int && alert.daily_limit_minor >= 0))
        && (!alert.keys().hasAny(['monthly_limit_minor']) || (alert.monthly_limit_minor is int && alert.monthly_limit_minor >= 0));
    }

    function isValidUserCreate(uid) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'uid',
          'email',
          'display_name',
          'photo_url',
          'role',
          'family_id',
          'member_status',
          'created_at',
          'updated_at',
          'preferences',
          'spending_alert'
        ])
        && data.keys().hasAll([
          'uid',
          'email',
          'display_name',
          'role',
          'member_status',
          'created_at',
          'updated_at'
        ])
        && data.uid == uid
        && data.email is string
        && data.display_name is string
        && data.display_name.size() > 0
        && data.display_name.size() <= 80
        && validRole(data.role)
        && validMemberStatus(data.member_status)
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && (!data.keys().hasAny(['photo_url']) || data.photo_url == null || data.photo_url is string)
        && (!data.keys().hasAny(['family_id']) || data.family_id == null || data.family_id is string)
        && (!data.keys().hasAny(['preferences']) || (data.preferences is map && isValidPreferences(data.preferences)))
        && (!data.keys().hasAny(['spending_alert']) || (data.spending_alert is map && isValidSpendingAlert(data.spending_alert)));
    }

    function isValidUserSelfUpdate(uid) {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isSelf(uid)
        && diff.hasOnly(['display_name', 'photo_url', 'updated_at', 'preferences', 'spending_alert'])
        && data.uid == resource.data.uid
        && data.email == resource.data.email
        && data.role == resource.data.role
        && data.family_id == resource.data.family_id
        && data.member_status == resource.data.member_status
        && data.created_at == resource.data.created_at
        && data.display_name is string
        && data.display_name.size() > 0
        && data.display_name.size() <= 80
        && (!data.keys().hasAny(['photo_url']) || data.photo_url == null || data.photo_url is string)
        && data.updated_at is timestamp
        && (!data.keys().hasAny(['preferences']) || (data.preferences is map && isValidPreferences(data.preferences)))
        && (!data.keys().hasAny(['spending_alert']) || (data.spending_alert is map && isValidSpendingAlert(data.spending_alert)));
    }

    function isValidOcrMeta(data) {
      return !data.keys().hasAny(['ocr_meta'])
        || data.ocr_meta == null
        || (
          data.ocr_meta is map
          && data.ocr_meta.keys().hasOnly(['used', 'confidence'])
          && (!data.ocr_meta.keys().hasAny(['used']) || data.ocr_meta.used is bool)
          && (!data.ocr_meta.keys().hasAny(['confidence'])
            || data.ocr_meta.confidence == null
            || data.ocr_meta.confidence is int
            || data.ocr_meta.confidence is float)
        );
    }

    function validEvidenceMimeType(mimeType) {
      return mimeType == 'image/jpeg' || mimeType == 'image/png';
    }

    function isValidCloudinaryEvidenceUrl(url) {
      return url is string
        && url.size() > 0
        && url.size() <= 2048
        && url.matches('^https://res\\.cloudinary\\.com/[^/]+/image/upload/.*$');
    }

    function isValidEvidenceImagePayload(image) {
      return image is map
        && image.keys().hasOnly([
          'storage_path',
          'file_name',
          'mime_type',
          'uploaded_at'
        ])
        && image.keys().hasAll(['storage_path', 'mime_type'])
        && isValidCloudinaryEvidenceUrl(image.storage_path)
        && (!image.keys().hasAny(['file_name'])
          || image.file_name == null
          || (image.file_name is string
            && image.file_name.size() > 0
            && image.file_name.size() <= 160))
        && (!image.keys().hasAny(['mime_type'])
          || image.mime_type == null
          || (image.mime_type is string
            && validEvidenceMimeType(image.mime_type)))
        && (!image.keys().hasAny(['uploaded_at'])
          || image.uploaded_at == null
          || image.uploaded_at is timestamp);
    }

    function isValidEvidenceImageCreate(data) {
      return !data.keys().hasAny(['evidence_image'])
        || data.evidence_image == null
        || isValidEvidenceImagePayload(data.evidence_image);
    }

    function isValidEvidenceImageUpdate(data) {
      return !data.keys().hasAny(['evidence_image'])
        || data.evidence_image == null
        || (
          resource.data.keys().hasAny(['evidence_image'])
          && data.evidence_image == resource.data.evidence_image
        )
        || isValidEvidenceImagePayload(data.evidence_image);
    }

    function isValidTransactionCreate(uid) {
      let data = request.resource.data;
      return isSelf(uid)
        && requesterExists()
        && data.keys().hasOnly([
          'transaction_id',
          'user_id',
          'family_id',
          'type',
          'amount_minor',
          'currency',
          'category_key',
          'category_label',
          'category_icon',
          'note',
          'source',
          'merchant_name',
          'date_ts',
          'created_at',
          'updated_at',
          'ocr_meta',
          'evidence_image'
        ])
        && data.keys().hasAll([
          'transaction_id',
          'user_id',
          'family_id',
          'type',
          'amount_minor',
          'currency',
          'category_key',
          'category_label',
          'date_ts',
          'created_at',
          'updated_at'
        ])
        && data.transaction_id is string
        && data.transaction_id.size() > 0
        && data.user_id == uid
        && data.family_id == requesterDoc().data.family_id
        && validTransactionType(data.type)
        && data.amount_minor is int
        && data.amount_minor > 0
        && data.currency == 'VND'
        && data.category_key is string
        && data.category_key.size() > 0
        && data.category_key.size() <= 40
        && data.category_label is string
        && data.category_label.size() > 0
        && data.category_label.size() <= 50
        && (!data.keys().hasAny(['category_icon']) || data.category_icon == null || data.category_icon is string)
        && (!data.keys().hasAny(['note']) || data.note == null || (data.note is string && data.note.size() <= 300))
        && (!data.keys().hasAny(['source']) || (data.source is string && validTransactionSource(data.source)))
        && (!data.keys().hasAny(['merchant_name']) || data.merchant_name == null || (data.merchant_name is string && data.merchant_name.size() <= 120))
        && data.date_ts is timestamp
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && isValidOcrMeta(data)
        && isValidEvidenceImageCreate(data);
    }

    function isValidTransactionUpdate(uid) {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isSelf(uid)
        && diff.hasOnly([
          'type',
          'amount_minor',
          'currency',
          'category_key',
          'category_label',
          'category_icon',
          'note',
          'source',
          'merchant_name',
          'date_ts',
          'updated_at',
          'ocr_meta',
          'evidence_image'
        ])
        && data.transaction_id == resource.data.transaction_id
        && data.user_id == resource.data.user_id
        && data.family_id == resource.data.family_id
        && data.created_at == resource.data.created_at
        && validTransactionType(data.type)
        && data.amount_minor is int
        && data.amount_minor > 0
        && data.currency == 'VND'
        && data.category_key is string
        && data.category_key.size() > 0
        && data.category_key.size() <= 40
        && data.category_label is string
        && data.category_label.size() > 0
        && data.category_label.size() <= 50
        && (!data.keys().hasAny(['category_icon']) || data.category_icon == null || data.category_icon is string)
        && (!data.keys().hasAny(['note']) || data.note == null || (data.note is string && data.note.size() <= 300))
        && (!data.keys().hasAny(['source']) || (data.source is string && validTransactionSource(data.source)))
        && (!data.keys().hasAny(['merchant_name']) || data.merchant_name == null || (data.merchant_name is string && data.merchant_name.size() <= 120))
        && data.date_ts is timestamp
        && data.updated_at is timestamp
        && isValidOcrMeta(data)
        && isValidEvidenceImageUpdate(data);
    }

    function isValidCustomCategory(data, categoryId) {
      return data.keys().hasOnly([
          'category_id',
          'category_key',
          'label',
          'icon',
          'type',
          'is_active',
          'created_at'
        ])
        && data.keys().hasAll([
          'category_id',
          'category_key',
          'label',
          'type',
          'is_active',
          'created_at'
        ])
        && data.category_id == categoryId
        && data.category_key is string
        && data.category_key.size() > 0
        && data.category_key.size() <= 40
        && data.label is string
        && data.label.size() > 0
        && data.label.size() <= 40
        && (!data.keys().hasAny(['icon']) || data.icon == null || (data.icon is string && data.icon.size() <= 8))
        && validTransactionType(data.type)
        && data.is_active is bool
        && data.created_at is timestamp;
    }

    function isValidNotificationReadUpdate() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return diff.hasOnly(['is_read'])
        && data.notification_id == resource.data.notification_id
        && data.type == resource.data.type
        && data.title == resource.data.title
        && data.body == resource.data.body
        && data.target_type == resource.data.target_type
        && data.target_id == resource.data.target_id
        && data.created_at == resource.data.created_at
        && data.is_read is bool;
    }

    function isValidMonthlySummaryWrite(uid, monthKey) {
      let data = request.resource.data;
      return monthKey.matches('^[0-9]{4}-[0-9]{2}$')
        && data.keys().hasAll([
          'month_key',
          'user_id',
          'total_expense_minor',
          'total_income_minor',
          'transaction_count',
          'updated_at'
        ])
        && data.month_key == monthKey
        && data.user_id == uid
        && data.total_expense_minor is int
        && data.total_income_minor is int
        && data.transaction_count is int
        && data.updated_at is timestamp;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isParentViewingChild(uid);
      allow create: if isSelf(uid) && isValidUserCreate(uid);
      allow update: if isValidUserSelfUpdate(uid);
      allow delete: if false;

      match /transactions/{transactionId} {
        allow read: if isSelf(uid) || isParentViewingChild(uid);
        allow create: if isValidTransactionCreate(uid);
        allow update: if isValidTransactionUpdate(uid);
        allow delete: if false;
      }

      match /monthly_summaries/{monthKey} {
        allow read: if isSelf(uid) || isParentViewingChild(uid);
        allow create: if isSelf(uid) && isValidMonthlySummaryWrite(uid, monthKey);
        allow update: if isSelf(uid) && isValidMonthlySummaryWrite(uid, monthKey);
        allow delete: if false;
      }

      match /custom_categories/{categoryId} {
        allow read: if isSelf(uid);
        allow create: if isSelf(uid) && isValidCustomCategory(request.resource.data, categoryId);
        allow update: if isSelf(uid)
          && isValidCustomCategory(request.resource.data, resource.data.category_id)
          && request.resource.data.category_id == resource.data.category_id
          && request.resource.data.created_at == resource.data.created_at;
        allow delete: if isSelf(uid);
      }

      match /notifications/{notificationId} {
        allow read: if isSelf(uid);
        allow create, delete: if false;
        allow update: if isSelf(uid) && isValidNotificationReadUpdate();
      }
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create, update, delete: if false;

      match /members/{memberUid} {
        allow read: if isFamilyMember(familyId);
        allow create, update, delete: if false;
      }
    }

    match /app_public/faqs/items/{faqId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /app_public/config/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
